{
  "name": "heimrichhannot/contao-ux-turbo-encore",
  "type": "contao-bundle",
  "description": "This bundle brings Symfony UX Turbo integration to Encore Bundle enabled contao projects.",
  "license": "LGPL-3.0-or-later",
  "homepage": "https://github.com/heimrichhannot/contao-ux-turbo-encore",
  "authors": [
    {
      "name": "Heimrich & Hannot GmbH",
      "email": "digitales@heimrich-hannot.de",
      "homepage": "https://heimrich-hannot.de",
      "role": "developer"
    }
  ],
  "support": {
    "issues": "https://github.com/heimrichhannot/contao-ux-turbo-encore/issues"
  },
  "require": {
    "php": "^8.2",
    "contao/core-bundle": "^5.3",
    "heimrichhannot/contao-encore-contracts": "^1.0",
    "symfony/dependency-injection": "^6.4 || ^7.0",
    "symfony/http-kernel": "^6.4 || ^7.0",
    "symfony/ux-turbo": "^3.1"
  },
  "autoload": {
    "psr-4": {
      "HeimrichHannot\\ContaoUxTurboEncore\\": "src/"
    }
  },
  "extra": {
    "contao-manager-plugin": "HeimrichHannot\\ContaoUxTurboEncore\\ContaoManagerPlugin"
  }
}
